# ======================================================
# KIPAR - Variables d'environnement (exemple)
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer le vrai .env
# ======================================================

# -- App --
ENVIRONMENT=development
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=["http://localhost:3000"]

# -- Database --
DATABASE_URL=postgresql+asyncpg://kipar:kipar_dev@localhost:5432/kipar_db
POSTGRES_USER=kipar
POSTGRES_PASSWORD=kipar_dev
POSTGRES_DB=kipar_db

# -- Redis --
REDIS_URL=redis://localhost:6379/0

# -- Security --
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# -- Stripe (paiements EUR) --
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# -- PawaPay (Mobile Money Afrique) --
PAWAPAY_API_TOKEN=...
PAWAPAY_BASE_URL=https://api.sandbox.pawapay.io

# -- Twilio (SMS verification) --
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...
TWILIO_VERIFY_SERVICE_SID=VA...

# -- Resend (Email transactionnel) --
RESEND_API_KEY=re_...

# -- iDenfy (KYC verification identite) --
IDENFY_API_KEY=...
IDENFY_API_SECRET=...
IDENFY_BASE_URL=https://ivs.idenfy.com

# -- AirLabs (Tracking vol) --
AIRLABS_API_KEY=...

# -- Anthropic (KiparScan IA) --
ANTHROPIC_API_KEY=sk-ant-...

# -- Cloudinary (Avatars + photos colis) --
CLOUDINARY_CLOUD_NAME=...
CLOUDINARY_API_KEY=...
CLOUDINARY_API_SECRET=...
CLOUDINARY_UPLOAD_PRESET=kipar_avatars

# -- Google OAuth --
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...

# -- Apple OAuth (post-lancement) --
APPLE_CLIENT_ID=com.kipar.app

# -- DeepL (Traduction automatique messages) --
DEEPL_API_KEY=...

# -- Sentry (Monitoring erreurs) --
SENTRY_DSN=
